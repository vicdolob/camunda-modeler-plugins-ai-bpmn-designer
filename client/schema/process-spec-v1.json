{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProcessSpec v1.0",
  "description": "Intermediate structured representation for BPMN process generation",
  "type": "object",
  "required": ["specVersion", "process", "nodes", "flows"],
  "additionalProperties": false,
  "properties": {
    "specVersion": {
      "type": "string",
      "const": "1.0"
    },
    "process": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$" },
        "name": { "type": "string", "minLength": 1 },
        "isExecutable": { "type": "boolean", "default": true }
      }
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "processRef": { "type": ["string", "null"], "description": "Reference to a process ID. If null/absent, this is an empty pool (black-box participant)." }
        }
      }
    },
    "lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "participantRef": { "type": ["string", "null"] }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "type", "name"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$" },
          "type": {
            "type": "string",
            "enum": [
              "startEvent",
              "endEvent",
              "userTask",
              "serviceTask",
              "exclusiveGateway",
              "parallelGateway",
              "intermediateThrowEvent",
              "intermediateCatchEvent",
              "scriptTask",
              "businessRuleTask",
              "manualTask",
              "receiveTask",
              "sendTask",
              "callActivity",
              "subProcess",
              "eventSubProcess",
              "boundaryEvent"
            ]
          },
          "name": { "type": "string" },
          "documentation": { "type": "string", "description": "Element documentation shown in Camunda Modeler properties panel" },
          "laneRef": { "type": ["string", "null"] },
          "attachedToRef": { "type": ["string", "null"], "description": "For boundary events: ID of the task/subProcess this event is attached to" },
          "cancelActivity": { "type": "boolean", "default": true, "description": "For boundary events: true = interrupting, false = non-interrupting" },
          "eventType": { "type": ["string", "null"], "description": "For boundary/intermediate events: timer, error, signal, message, escalation, conditional", "enum": ["timer", "error", "signal", "message", "escalation", "conditional", null] },
          "properties": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "sourceRef", "targetRef"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$" },
          "sourceRef": { "type": "string" },
          "targetRef": { "type": "string" },
          "condition": { "type": ["string", "null"] },
          "name": { "type": ["string", "null"] },
          "documentation": { "type": ["string", "null"], "description": "Flow documentation shown in Camunda Modeler" }
        }
      }
    },
    "messageFlows": {
      "type": "array",
      "description": "Message flows connecting participants across pool boundaries",
      "items": {
        "type": "object",
        "required": ["id", "sourceRef", "targetRef"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$" },
          "sourceRef": { "type": "string", "description": "ID of the source participant, node, or event" },
          "targetRef": { "type": "string", "description": "ID of the target participant, node, or event" },
          "name": { "type": ["string", "null"] }
        }
      }
    },
    "dataObjects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    "dataStoreReferences": {
      "type": "array",
      "description": "Data store references that appear as visual elements on the diagram",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["textAnnotation", "group", "association"] },
          "text": { "type": ["string", "null"] },
          "sourceRef": { "type": ["string", "null"], "description": "For associations: source element ID" },
          "targetRef": { "type": ["string", "null"], "description": "For associations: target element ID" }
        }
      }
    }
  }
}
